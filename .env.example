ENV=development
SECRET_KEY=changeme_use_openssl_rand_hex_32_in_production
TZ=America/Santiago

# Database
DATABASE_URL=postgresql+asyncpg://xpacio:xpacio@db:5432/xpacio

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:8080/reserva/confirmacion?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:8080/reserva/cancelada

# MinIO (object storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=xpacio-spaces
MINIO_USE_SSL=false

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@xpacio.cl

# Nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
